                        ax=axes[i])

            axes[i].set_title(f'Confusion Matrix: {target_var} vs {dummy_var}', fontsize=6)  # Reduced title size
            axes[i].set_xlabel(f'{dummy_var}')
            axes[i].set_ylabel(f'{target_var}')

    # Hide any unused subplots
    for j in range(i + 1, len(axes)):
        fig.delaxes(axes[j])

    plt.tight_layout()
    plt.show()

