    x_hat = np.full(size, 1.1) # exact solution of the system
    vector_b = A @ x_hat # known vector

    LU = gaussLU(A)
    x, rnorm = solveLU(LU,vector_b)

    residual_norm = np.linalg.norm(x-x_hat)/np.linalg.norm(x)
    error_residual = rnorm/np.linalg.norm(vector_b)

    LU_piv, P = gaussLUP(A)
    x_piv, rnorm_piv = solveLUP(LU_piv, vector_b, P)

    residual_norm_pivot = np.linalg.norm(x_piv-x_hat)/np.linalg.norm(x_piv)
    error_residual_pivot = rnorm_piv/np.linalg.norm(vector_b)


    print(f'{size}  {np.linalg.cond(A):.2e}  {residual_norm:.2e} {residual_norm_pivot:.2e}   {error_residual:.2e}   {error_residual_pivot:.2e}')

