def load_data(train_transform, test_transform, batch_size=256, val_size=2000, random_seed=42, subset=None):

    torch.manual_seed(random_seed)

    # Load training dataset
    trainset = torchvision.datasets.CIFAR10(
        root='./data',
        train=True,
        download=True,
        transform=train_transform
    )

    # define subset as fraction
    if subset is not None:
        if isinstance(subset, float):
            subset_size = int(len(trainset) * subset)
        else:
            subset_size = subset

        if subset_size < val_size:
            raise ValueError("The subset size must be larger than the validation size.")

        indices_full = torch.randperm(len(trainset))[:subset_size]
    else:
        indices_full = torch.randperm(len(trainset))

    # Split indices into validation and training indices
    val_indices = indices_full[:val_size]
    train_indices = indices_full[val_size:]

    # Create samplers for the training and validation sets
    train_sampler = SubsetRandomSampler(train_indices)
    val_sampler = SubsetRandomSampler(val_indices)

    # Create data loaders for training and validation
    train_loader = DataLoader(trainset, batch_size=batch_size, sampler=train_sampler)
    val_loader = DataLoader(trainset, batch_size=batch_size, sampler=val_sampler)

    # Load test dataset
    testset = torchvision.datasets.CIFAR10(
        root='./data',
        train=False,
        download=True,
        transform=test_transform
    )

    # reduce the test dataset if 'subset' is specified
    if subset is not None:
        if isinstance(subset, float):
            test_subset_size = int(len(testset) * subset)
        else:
            test_subset_size = subset

        test_indices = torch.randperm(len(testset))[:test_subset_size]
        test_sampler = SubsetRandomSampler(test_indices)
        test_loader = DataLoader(testset, batch_size=batch_size, sampler=test_sampler)
    else:
        test_loader = DataLoader(testset, batch_size=batch_size, shuffle=False)

    return train_loader, val_loader, test_loader, train_indices, val_indices

