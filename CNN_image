### Exercise 2.2: Train and Evaluate your MLP Baseline

Train the model for a few (say, 20) epochs. Again, feel free to use my training code from the Capsule Lecture (or roll your own, mine is very basic). Make sure you plot training curves and report accuracy on the test set.

# **2.2.1) Training process**
"""

# -------------------------
# 2.2.1 Training Function
# -------------------------

def train(model, optimizer, loss_fn, train_loader, val_loader, epochs=20, device="cpu"):
    model.to(device)
    train_losses = []
    val_losses = []
    val_accuracies = []

    for epoch in range(1, epochs + 1):
        model.train()
        training_loss = 0.0
        total_train_samples = 0

        for batch_idx, (inputs, targets) in enumerate(train_loader):
            optimizer.zero_grad() #zero gradient for each batch
            inputs, targets = inputs.to(device), targets.to(device)
            outputs = model(inputs)
            loss = loss_fn(outputs, targets)# calculate loss
            loss.backward() # backward propagation
            optimizer.step() # optimizer for gradient

            batch_size = inputs.size(0)
            training_loss += loss.item() * batch_size
            total_train_samples += batch_size
        training_loss /= total_train_samples # calculate loss for epoch

        # Validation Phase
        model.eval() # stop train the model for evaluation
        valid_loss = 0.0
        total_val_samples = 0
        correct_val = 0
        with torch.no_grad():
            for batch_idx, (inputs, targets) in enumerate(val_loader):
                inputs, targets = inputs.to(device), targets.to(device)
                outputs = model(inputs) # predict
                loss = loss_fn(outputs, targets)
                batch_size = inputs.size(0)
                valid_loss += loss.item() * batch_size
                total_val_samples += batch_size
                predicted = outputs.argmax(dim=1)
                correct_val += (predicted == targets).sum().item()
        valid_loss /= total_val_samples
        val_accuracy = correct_val / total_val_samples

        train_losses.append(training_loss)
        val_losses.append(valid_loss)
        val_accuracies.append(val_accuracy)

        print(f"Epoch: {epoch:02d} | Train Loss: {training_loss:.4f} | Val Loss: {valid_loss:.4f} | Val Acc: {val_accuracy:.4f}")

    # Plot Losses
    epochs_range = range(1, epochs + 1)
    plt.figure(figsize=(10, 5))
    plt.plot(epochs_range, train_losses, label="Training Loss")
    plt.plot(epochs_range, val_losses, label="Validation Loss")
    plt.xlabel("Epoch")
    plt.ylabel("Loss")
    plt.title("Loss per Epoch")
    plt.legend()
    plt.show()

    # Plot Validation Accuracy
    plt.figure(figsize=(10, 5))
    plt.plot(epochs_range, val_accuracies, label="Validation Accuracy")
    plt.xlabel("Epoch")
    plt.ylabel("Accuracy")
    plt.title("Validation Accuracy per Epoch")
    plt.legend()
    plt.show()

    return train_losses, val_losses, val_accuracies

"""Per questa parte è stato ripreso il codice visto a lezione. Vengono imposte 20 epoche che rappresenta il numero di volte che l'algoritmo vede tutto il dataset. Per ogni volta i dati vengono presi a gruppi di dimensioni pari a batchsize, sulla quale viene applicata la Loss selezionata, che in questo caso essendo un problema di classificazione è stata scelta la CrossEntropyLoss. L'algoritmo di ottimizzazione è ADAM che è simile allo SGD ma aggiusta il gradiente per il momento primo e secondo. Per ogni batch calcola la loss ed esegue la backpropagation aggiornando i parametri. I parametri vengono usati nel validation set per valutare la loss e l'accuracy in modo da valutare overfitting (imponendo model.eval() senza quindi aggiornare i parametri). Il criterio di arresto è il numero di iterazioni controllato dal numero di epoch. Il learning rate dell'ADAM è stato imposto a 0.001. E' stato testato anche un learning rate di 0.0001 (test non presentato nel codice). Per ogni batch viene azzerato il gradiente per l'ottimizzazione. I pesi del modello non vengono inizializzati esplicitamente; pytorch di default inizializza i pesi come 0 per il bias e utilizzando il metodo Kaiming per i w.

# **2.2.2) Test process**
"""

# -------------------------
# 2.2.2. Test Function
# -------------------------

def test(model, loss_fn, test_loader, device="cpu"):
    model.to(device)
    model.eval()
    total_loss = 0.0
    total_samples = 0
    correct = 0
    with torch.no_grad():
        for batch_idx, (inputs, targets) in enumerate(test_loader):
            inputs, targets = inputs.to(device), targets.to(device)
            outputs = model(inputs)
            loss = loss_fn(outputs, targets)
            batch_size = inputs.size(0)
            total_loss += loss.item() * batch_size
            total_samples += batch_size
            predicted = outputs.argmax(dim=1)
            correct += (predicted == targets).sum().item()
    avg_loss = total_loss / total_samples
    accuracy = correct / total_samples
    print(f"Final Test Loss: {avg_loss:.4f}, Final Test Accuracy: {accuracy:.4f}")
    return avg_loss, accuracy

