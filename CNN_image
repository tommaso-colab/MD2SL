# Calculat mean and stdv for dataset for each layer
def calculate_mean_std(dataloader):
    """Compute mean and standard deviation for a dataset."""
    sum_, sum_sq, num_samples = 0.0, 0.0, 0

    for images, _ in dataloader:  # Extract images only
        images = images.float()  # Convert to float
        batch_size = images.size(0)
        num_samples += batch_size

        sum_ += images.mean(dim=[0, 2, 3]) * batch_size  # Mean across (H, W)
        sum_sq += (images ** 2).mean(dim=[0, 2, 3]) * batch_size  # Squared mean

    mean = sum_ / num_samples
    std = torch.sqrt(sum_sq / num_samples - mean ** 2)

    return mean, std

